generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  name      String
  createdAt DateTime @default(now())
  uploads   Upload[]
}

model Upload {
  id         String    @id @default(uuid())
  filename   String
  originalName String
  size       Int
  status     String    @default("pending") // pending | processing | completed | failed
  createdAt  DateTime  @default(now())
  userId     String
  user       User      @relation(fields: [userId], references: [id])
  analysis   Analysis?
  logEntries LogEntry[]
}

model LogEntry {
  id          String   @id @default(uuid())
  uploadId    String
  upload      Upload   @relation(fields: [uploadId], references: [id], onDelete: Cascade)
  lineNumber  Int
  timestamp   DateTime?
  sourceIp    String?
  method      String?
  url         String?
  statusCode  Int?
  userAgent   String?
  bytesSent   Int?
  responseTime Float?
  rawLine     String
  isAnomaly   Boolean  @default(false)
  anomalyReason String?
  anomalyScore  Float?
  createdAt   DateTime @default(now())

  @@index([uploadId])
  @@index([sourceIp])
  @@index([timestamp])
}

model Analysis {
  id              String   @id @default(uuid())
  uploadId        String   @unique
  upload          Upload   @relation(fields: [uploadId], references: [id], onDelete: Cascade)
  summary         String   // AI-generated summary
  timeline        Json     // Array of timeline events
  threatLevel     String   // low | medium | high | critical
  totalEntries    Int
  anomalyCount    Int
  topIps          Json     // Array of {ip, count}
  statusBreakdown Json     // {2xx, 3xx, 4xx, 5xx counts}
  keyFindings     Json     // Array of key findings for SOC analyst
  createdAt       DateTime @default(now())
}
